# Cloudflare Pages — Option A: deploy hook (recommended, simpler)
# Get this from: Cloudflare Dashboard → Pages → your project → Settings → Builds & Deployments → Deploy Hooks
CF_DEPLOY_HOOK_URL=

# Cloudflare Pages — Option B: API (used if CF_DEPLOY_HOOK_URL is not set)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_PROJECT_NAME=cs-analytics
